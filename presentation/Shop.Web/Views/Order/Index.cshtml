@model OrderModel
@{
    ViewData["Title"] = "Выбранные автомобили";
}
<h1>Выбранные автомобили</h1>

<table class="table table-sm table-striped">
    <thead class="thead-dark">
        <tr>
            <th scope="col">№</th>
            <th scope="col">Марка</th>
            <th scope="col">Модель</th>
            <th scope="col">Количество</th>
            <th scope="col">Стоимость</th>
            <th scope="col"></th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Items.Length; i++)
        {
            <tr>
                <td class="text-right">@(i+1)</td>
                <td>@Model.Items[i].Brand</td>
                <td>@Model.Items[i].Model</td>
                <td class="text-right">@Model.Items[i].Count</td>
                <td class="text-right">@Model.Items[i].Price</td>
                <td class="text-center">
                    <form class="form-inline" action="@Url.Action("RemoveItem", "Order")" method="post">
                        <input type="hidden" name="carId" value="@Model.Items[i].CarId" />
                        <button class="btn btn-danger" type="submit">Удалить</button>
                    </form>
                </td>
                
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <td colspan="3" class="text-right">Итог</td>
            <td class="text-right">@Model.TotalCount</td>
            <td class="text-right">@Model.TotalPrice</td>
            
        </tr>
    </tfoot>
</table>
