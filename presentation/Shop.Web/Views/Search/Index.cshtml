@model Car[]
   

@{
    ViewData["Model"] = "Результат поиска";
}

<h1>Результаты поиска</h1>

@if (Model.Length == 0)
{
    <p>Ничего не найдено.</p>
}
else
{
    <ul>
       @foreach (var car in Model)
        {
            <li>
                <a href ="@Url.Action("Index","Car", new{id = car.Id})">@car.Brand</a>
            </li>
        }
    </ul>
}
